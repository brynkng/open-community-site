# =========================================================================
# Copy this file to `.dev.vars` for local dev (wrangler reads .dev.vars),
# and set the same keys as Cloudflare secrets for production:
#   wrangler secret put ADMIN_PASSWORD
#   ...etc
# NEVER commit real values.
# =========================================================================

# --- Admin login ---
# The single admin password used to sign in at /admin/login
ADMIN_PASSWORD="change-me-to-a-long-random-string"
# Secret used to sign the admin session cookie (32+ random chars)
SESSION_SECRET="generate-with: openssl rand -base64 32"

# --- Resend (email newsletter + RSVP confirmations) ---
# Free tier: https://resend.com  (100 emails/day, 3k/mo)
RESEND_API_KEY="re_xxxxxxxx"
# A verified sender on your domain, e.g. hello@yourgroup.org
EMAIL_FROM="Our Community <hello@yourgroup.org>"

# --- Instagram Graph API (publishing) ---
# Instagram Business/Creator account ID (numeric)
IG_USER_ID="1784xxxxxxxxxxx"
# Meta app credentials (from developers.facebook.com)
IG_APP_ID="xxxxxxxxxxxxxxx"
IG_APP_SECRET="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# Initial long-lived user access token (~60 days). The daily cron refreshes it
# and stores the current token in KV; this is only the seed value.
IG_SEED_LONG_LIVED_TOKEN="EAAxxxxxxxxxxxx"

# --- Cron protection ---
# Random secret required to call /api/cron/* routes if you trigger them via HTTP.
CRON_SECRET="generate-with: openssl rand -base64 32"
